{
  "name": "daily-log-vps",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx ts-node-dev --respawn server.ts",
    "build": "tsc -p tsconfig.json && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build && node -e \"const fs=require('fs');fs.cpSync('dist','../public',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "vitest": "^1.2.0"
  }
}
